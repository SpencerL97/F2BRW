{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "mcp__interactive-brokers__(create|delete)_order_instruction",
        "hooks": [
          { "type": "command", "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/pre-tool-use.sh" }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(sqlite3:*)",
      "Bash(python:*)",
      "Bash(python3:*)",
      "Bash(pip:*)"
    ]
  }
}
