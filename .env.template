# Copy this file to .env and fill in your actual values.
# .env is gitignored. Never commit real keys.

# IBKR account mode flag. Must match the actual mode of the IBKR account
# linked to your MCP authorization. The PreToolUse hook reads this to decide
# whether to require the live-confirmation phrase.
# Values: paper | live
TRADING_MODE=paper

# Optional: starting equity for sizing math before account is funded / pulled
DEFAULT_EQUITY=100000

# Optional: Unusual Whales API key (drop in when you subscribe)
UNUSUAL_WHALES_API_KEY=

# Optional: FMP API key if your tier requires one
FMP_API_KEY=
